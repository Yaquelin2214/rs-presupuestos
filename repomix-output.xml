import React, { useState } from 'react';
import { Save, Plus, ArrowLeft, FileText } from 'lucide-react';
import { useNavigate } from 'react-router-dom';
import { presupuestoService } from '../services/PresupuestoService';
import { PDFDownloadLink } from '@react-pdf/renderer';
import PDFPresupuesto from '../components/PDFPresupuesto';
import imgFondo from "../assets/fondo_obra.jpg";

const PresupuestoSimple = () => {
  const navigate = useNavigate();
  const [cargando, setCargando] = useState(false);
  const [cliente, setCliente] = useState({ nombre: '', telefono: '', direccion: '' });
  
  const [manoObra, setManoObra] = useState([
    { cant: '', detalle: '', precio: '', total: 0 }
  ]);

  const updateRow = (index, field, value) => {
    const list = [...manoObra];
    list[index][field] = value;
    
    if (field === 'cant' || field === 'precio') {
      const c = parseFloat(list[index].cant) || 0;
      const p = parseFloat(list[index].precio) || 0;
      list[index].total = c * p;
    }
    setManoObra(list);
  };

  const agregarFila = () => {
    setManoObra([...manoObra, { cant: '', detalle: '', precio: '', total: 0 }]);
  };

  const totalFinal = manoObra.reduce((acc, i) => acc + i.total, 0);

  const guardarPresupuesto = async () => {
    if (!cliente.nombre) return alert("Por favor, pon el nombre del cliente");
    setCargando(true);
    
    const datos = {
      clienteNombre: cliente.nombre,
      clienteTelefono: cliente.telefono,
      clienteDireccion: cliente.direccion,
      manoObra,
      totalFinal,
      tipo: 'simple',
      fecha: new Date().toISOString()
    };

    const res = await presupuestoService.crear(datos);
    if (res.success) {
      alert("Presupuesto guardado con éxito");
    }
    setCargando(false);
  };

  return (
    <div className="bg-obra-layout" style={{ backgroundImage: `url(${imgFondo})` }}>
      {/* Capa oscura de fondo para coherencia visual */}
      <div className="overlay-oscuro"></div>

      {/* Carpeta Blanca Estilo Documento */}
      <div className="carpeta-blanca">
        
        {/* Encabezado con tu Logo Estilo */}
        <div className="flex justify-between items-start mb-8">
          <button onClick={() => navigate('/')} className="flex items-center gap-2 text-slate-400 hover:text-blue-600 transition-colors uppercase text-xs font-black">
            <ArrowLeft size={18}/> Volver al Inicio
          </button>
          <div className="text-right">
            <h1 className="text-2xl font-black text-slate-800 tracking-tighter">RS GESTIÓN</h1>
            <p className="text-blue-600 text-[10px] font-bold uppercase tracking-[0.3em]">Solo Mano de Obra</p>
          </div>
        </div>

        <h2 className="text-xl font-black text-slate-700 mb-6 uppercase tracking-widest border-l-4 border-blue-500 pl-4">
          Presupuesto Mano de Obra
        </h2>

        {/* DATOS DEL CLIENTE */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10 bg-slate-50 p-6 rounded-2xl border border-slate-100">
          <div className="space-y-1">
            <label className="text-[10px] font-black text-slate-400 ml-1 uppercase">Cliente</label>
            <input 
              className="w-full p-3 bg-white rounded-xl border-none shadow-sm focus:ring-2 focus:ring-blue-500" 
              placeholder="Nombre completo"
              value={cliente.nombre}
              onChange={(e) => setCliente({...cliente, nombre: e.target.value})}
            />
          </div>
          <div className="space-y-1">
            <label className="text-[10px] font-black text-slate-400 ml-1 uppercase">Contacto</label>
            <input 
              className="w-full p-3 bg-white rounded-xl border-none shadow-sm focus:ring-2 focus:ring-blue-500" 
              placeholder="+56 9..."
              value={cliente.telefono}
              onChange={(e) => setCliente({...cliente, telefono: e.target.value})}
            />
          </div>
          <div className="space-y-1">
            <label className="text-[10px] font-black text-slate-400 ml-1 uppercase">Ubicación Obra</label>
            <input 
              className="w-full p-3 bg-white rounded-xl border-none shadow-sm focus:ring-2 focus:ring-blue-500" 
              placeholder="Dirección del proyecto"
              value={cliente.direccion}
              onChange={(e) => setCliente({...cliente, direccion: e.target.value})}
            />
          </div>
        </div>

        {/* TABLA: DETALLE LABOR */}
        <section className="mb-8">
          <h3 className="text-xs font-black text-blue-600 mb-4 uppercase tracking-widest flex items-center gap-2">
            <span className="bg-blue-600 text-white w-5 h-5 flex items-center justify-center rounded-full text-[10px]">1</span>
            Detalle de Labores Realizadas
          </h3>
          <div className="overflow-x-auto rounded-2xl border border-slate-100 shadow-sm">
            <table className="w-full bg-white">
              <thead>
                <tr className="bg-slate-800 text-white text-[10px] uppercase tracking-widest">
                  <th className="p-4 text-center w-20">Cant.</th>
                  <th className="p-4 text-left">Descripción del Servicio</th>
                  <th className="p-4 text-right w-32">P. Unitario</th>
                  <th className="p-4 text-right w-32">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                {manoObra.map((item, idx) => (
                  <tr key={idx} className="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
                    <td>
                      <input 
                        type="number" 
                        className="w-full p-2 bg-transparent text-center font-bold text-blue-600 border-none focus:ring-0 appearance-none" 
                        placeholder="0"
                        value={item.cant} 
                        onChange={(e) => updateRow(idx, 'cant', e.target.value)} 
                      />
                    </td>
                    <td>
                      <input 
                        type="text" 
                        className="w-full p-2 bg-transparent border-none focus:ring-0" 
                        placeholder="Ej: Instalación red agua caliente" 
                        value={item.detalle} 
                        onChange={(e) => updateRow(idx, 'detalle', e.target.value)} 
                      />
                    </td>
                    <td>
                      <input 
                        type="number" 
                        className="w-full p-2 bg-transparent text-right border-none focus:ring-0 appearance-none" 
                        placeholder="0"
                        value={item.precio} 
                        onChange={(e) => updateRow(idx, 'precio', e.target.value)} 
                      />
                    </td>
                    <td className="p-4 text-right font-black text-slate-700 bg-slate-50/30">
                      ${item.total.toLocaleString()}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <button 
            onClick={agregarFila} 
            className="mt-4 px-4 py-2 text-blue-600 font-black text-[10px] flex items-center gap-2 hover:bg-blue-50 rounded-xl transition-all border-2 border-dashed border-blue-100 uppercase tracking-tighter"
          >
            <Plus size={14}/> Agregar nueva línea de trabajo
          </button>
        </section>

        {/* BLOQUE DE ACCIONES Y RESULTADO */}
        <div className="flex flex-col md:flex-row justify-between items-center gap-6 border-t pt-10 mt-10">
          <div className="flex gap-3">
            <button 
              onClick={guardarPresupuesto}
              disabled={cargando}
              className="bg-slate-900 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg shadow-slate-200"
            >
              {cargando ? 'Procesando...' : '1. Guardar Obra'}
            </button>

            <PDFDownloadLink 
              document={<PDFPresupuesto datos={{...cliente, manoObra, totalFinal}} tipo="simple" />} 
              fileName={`Cotizacion_MO_${cliente.nombre}.pdf`}
            >
              {({ loading }) => (
                <button className="bg-blue-600 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-700 transition-all shadow-lg flex items-center gap-2">
                  <FileText size={18}/> {loading ? 'Cargando...' : '2. Descargar PDF'}
                </button>
              )}
            </PDFDownloadLink>
          </div>

          <div className="text-right bg-slate-900 p-6 rounded-3xl min-w-[260px] shadow-xl border border-white/10">
            <p className="text-blue-400 text-[10px] uppercase font-black tracking-widest mb-1">Mano de Obra Total</p>
            <p className="text-4xl font-black text-white">${totalFinal.toLocaleString()}</p>
          </div>
        </div>
      </div>
    </div>
  );
};

export default PresupuestoSimple;
</file>

